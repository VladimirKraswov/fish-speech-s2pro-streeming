{
  "version": 1,
  "paths": {
    "llama_checkpoint_path": "checkpoints/fs-1.2-int8-s2-pro-int8",
    "decoder_checkpoint_path": "checkpoints/s2-pro/codec.pth",
    "decoder_config_name": "modded_dac_vq",
    "references_dir": "references"
  },
  "network": {
    "server": {
      "host": "0.0.0.0",
      "port": 8080
    },
    "proxy": {
      "host": "0.0.0.0",
      "port": 9000
    },
    "upstream_tts_url": "http://server:8080/v1/tts"
  },
  "model": {
    "device": "cuda",
    "precision": "bfloat16",
    "compile": true,
    "cache_max_seq_len": 1280,
    "max_new_tokens_cap": 300,
    "sdpa_math": false,

    "cleanup_after_request": false,
    "cleanup_every_n_requests": 12,
    "cleanup_on_error": true,
    "cleanup_on_abort": true,
    "empty_cache_per_stream_chunk": false,
    "empty_cache_per_segment": false,

    "profile_inference": false,
    "record_memory_history": false,
    "memory_history_max_entries": 100000,

    "long_form_auto_split": true,
    "long_form_target_chars": 170,
    "long_form_max_chars": 250,
    "long_form_context_policy": "tail_frames",
    "long_form_tail_frames": 48,
    "long_form_max_history_segments": 1,
    "long_form_tokens_per_char": 1.3,
    "long_form_token_overhead": 32,
    "long_form_min_new_tokens": 64,
    "long_form_max_new_tokens_per_segment": 300
  },
  "warmup": {
    "enabled": true,
    "reference_id": "voice",
    "text": "Привет. Это дополнительный прогрев стримингового режима для Fish Speech.",
    "streaming": true,
    "stream_tokens": true,
    "max_new_tokens": 220,
    "chunk_length": 200,
    "initial_stream_chunk_size": 24,
    "stream_chunk_size": 18
  },
  "proxy": {
    "default_reference_id": "voice",
    "session_ttl_sec": 1800,
    "session_max_count": 128,
    "version": 1,
    "commit": {
      "first": {
        "min_chars": 14,
        "target_chars": 32,
        "max_chars": 72,
        "max_wait_ms": 180,
        "allow_partial_after_ms": 420
      },
      "next": {
        "min_chars": 70,
        "target_chars": 145,
        "max_chars": 220,
        "max_wait_ms": 650,
        "allow_partial_after_ms": 1350
      },
      "flush_on_sentence_punctuation": true,
      "flush_on_clause_punctuation": false,
      "flush_on_newline": true,
      "carry_incomplete_tail": true
    },
    "tts": {
      "reference_id": "voice",
      "format": "wav",
      "normalize": true,
      "use_memory_cache": "on",
      "seed": null,
      "max_new_tokens": 300,
      "chunk_length": 200,
      "top_p": 0.82,
      "repetition_penalty": 1.03,
      "temperature": 0.7,
      "stream_tokens": true,
      "initial_stream_chunk_size": 28,
      "stream_chunk_size": 20,
      "first_initial_stream_chunk_size": 10,
      "first_stream_chunk_size": 8,
      "stateful_synthesis": true,
      "stateful_fallback_to_stateless": false,
      "stateful_history_turns": 1,
      "stateful_history_chars": 160,
      "stateful_history_code_frames": 120,
      "stateful_reset_every_commits": 4,
      "stateful_reset_every_chars": 800
    },
    "playback": {
      "target_emit_bytes": 24576,
      "start_buffer_ms": 300,
      "first_commit_target_emit_bytes": 8192,
      "first_commit_start_buffer_ms": 120,
      "client_start_buffer_ms": 160,
      "client_initial_start_delay_ms": 40,
      "stop_grace_ms": 0,
      "boundary_smoothing_enabled": true,
      "punctuation_pauses_enabled": true,
      "fade_in_ms": 8,
      "fade_out_ms": 12,
      "pause_after_clause_ms": 110,
      "pause_after_sentence_ms": 280,
      "pause_after_newline_ms": 520,
      "pause_after_force_ms": 220,
      "pause_after_hard_limit_ms": 40
    },
    "session": {
      "max_buffer_chars": 20000,
      "auto_close_on_finish": false
    }
  },
  "frontend_overrides": {
    "enabled": true,
    "allowed_paths": [
      "commit.first.min_chars",
      "commit.first.target_chars",
      "commit.first.max_chars",
      "commit.first.max_wait_ms",
      "commit.first.allow_partial_after_ms",
      "commit.next.min_chars",
      "commit.next.target_chars",
      "commit.next.max_chars",
      "commit.next.max_wait_ms",
      "commit.next.allow_partial_after_ms",
      "commit.carry_incomplete_tail",
      "commit.flush_on_sentence_punctuation",
      "commit.flush_on_clause_punctuation",
      "commit.flush_on_newline",
      "tts.reference_id",
      "tts.format",
      "tts.normalize",
      "tts.use_memory_cache",
      "tts.seed",
      "tts.max_new_tokens",
      "tts.chunk_length",
      "tts.top_p",
      "tts.repetition_penalty",
      "tts.temperature",
      "tts.stream_tokens",
      "tts.initial_stream_chunk_size",
      "tts.stream_chunk_size",
      "tts.first_initial_stream_chunk_size",
      "tts.first_stream_chunk_size",
      "tts.stateful_synthesis",
      "tts.stateful_fallback_to_stateless",
      "tts.stateful_history_turns",
      "tts.stateful_history_chars",
      "tts.stateful_history_code_frames",
      "tts.stateful_reset_every_commits",
      "tts.stateful_reset_every_chars",
      "playback.target_emit_bytes",
      "playback.start_buffer_ms",
      "playback.first_commit_target_emit_bytes",
      "playback.first_commit_start_buffer_ms",
      "playback.client_start_buffer_ms",
      "playback.client_initial_start_delay_ms",
      "playback.stop_grace_ms",
      "playback.boundary_smoothing_enabled",
      "playback.punctuation_pauses_enabled",
      "playback.fade_in_ms",
      "playback.fade_out_ms",
      "playback.pause_after_clause_ms",
      "playback.pause_after_sentence_ms",
      "playback.pause_after_newline_ms",
      "playback.pause_after_force_ms",
      "playback.pause_after_hard_limit_ms",
      "session.max_buffer_chars",
      "session.auto_close_on_finish"
    ]
  }
}
