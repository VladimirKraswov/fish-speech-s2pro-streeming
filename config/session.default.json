{
  "version": 1,
  "committer": {
    "soft_min_chars": 40,
    "target_chars": 120,
    "hard_max_chars": 180,
    "flush_on_punctuation": true,
    "flush_on_clause_punctuation": true,
    "flush_on_newline": true,
    "max_wait_ms": 900,
    "allow_partial_after_ms": 1400,
    "carry_incomplete_tail": true
  },
  "tts": {
    "reference_id": "voice",
