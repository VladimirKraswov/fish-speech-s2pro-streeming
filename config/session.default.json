{
  "committer": {
    "soft_min_chars": 140,
    "target_chars": 220,
    "hard_max_chars": 320,
    "flush_on_punctuation": true,
    "flush_on_clause_punctuation": false,
    "flush_on_newline": true,
    "max_wait_ms": 1800,
    "allow_partial_after_ms": 3500,
    "carry_incomplete_tail": true
  },
  "tts": {
    "max_new_tokens": 128,
    "chunk_length": 200,
    "stream_tokens": true,
    "initial_stream_chunk_size": 18,
    "stream_chunk_size": 8
  },
  "playback": {
    "target_emit_bytes": 16384,
    "start_buffer_ms": 450,
    "stop_grace_ms": 250
  }
}