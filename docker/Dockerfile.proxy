FROM python:3.12-slim
RUN apt-get update && apt-get install -y --no-install-recommends curl libsox-dev ffmpeg && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY fish_speech_server/proxy/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY fish_speech_server fish_speech_server
ENV FISH_UPSTREAM_TTS_URL=http://server:8080/v1/tts
CMD ["uvicorn", "fish_speech_server.proxy.pcm:app", "--host", "0.0.0.0", "--port", "9000"]